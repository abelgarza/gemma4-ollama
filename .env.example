# Ollama Config
OLLAMA_MODEL=gemma4-audio:latest
OLLAMA_HOST=http://localhost:11434

# Memory Configuration
EMBEDDING_MODEL=embeddinggemma:300m-qat-q4_0
MEMORY_JSONL_PATH=data/memory/memory.jsonl
VECTOR_DB_PATH=data/memory/vectors.sqlite

# Audio Recording Config
AUDIO_SOURCE=default
AUDIO_SAMPLE_RATE=16000

# TTS Config
# Velocidad del TTS (1.0 es normal, 1.2 es ligeramente más rápido)
TTS_SPEED=1.2
TTS_LANG=es

# Chat Config
RECORDING_SECONDS=5.0
KEEP_AUDIO=false
