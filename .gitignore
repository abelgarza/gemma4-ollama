__pycache__/
*.py[cod]
.venv/
.envrc
.env
*.egg-info/
dist/
build/

# === Data Security ===
# Ignore everything in data/
data/**/*

# Allow directory structure through .gitkeep files
!data/**/
!data/**/*.gitkeep

# Explicitly allow the test sample
!data/sample-audio/sample.wav
!data/sample-image/sample.png
